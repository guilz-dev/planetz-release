{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/out",
      "!**/dist",
      "!**/node_modules",
      "!pnpm-lock.yaml",
      "!third_party",
      "!vendor",
      "!docs",
      "!apps/desktop/resources",
      "!apps/desktop/fixtures",
      "!pitch"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.test.tsx", "**/__tests__/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/landing/**"],
      "linter": {
        "rules": {
          "style": {
            "noDescendingSpecificity": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/desktop/src/renderer/src/components/report-markdown-content.tsx",
        "apps/desktop/src/renderer/src/components/mock/**",
        "apps/desktop/src/renderer/src/components/task-result-diff-dialog.tsx",
        "apps/desktop/src/renderer/src/components/prompt-composer.tsx",
        "apps/desktop/src/renderer/src/components/settings/workflow-step-output-contracts-editor.tsx",
        "apps/desktop/src/renderer/src/skins/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noArrayIndexKey": "off"
          },
          "a11y": {
            "noSvgWithoutTitle": "off",
            "useSemanticElements": "off",
            "useButtonType": "off",
            "useAriaPropsSupportedByRole": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/desktop/src/main/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/desktop/src/renderer/src/components/settings/**"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/desktop/src/renderer/src/components/task-card.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/desktop/src/renderer/src/components/workflow-group-header.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/desktop/src/renderer/src/components/prompt-composer.tsx",
        "apps/desktop/src/renderer/src/components/main-dashboard.tsx"
      ],
      "linter": {
        "rules": {
          "correctness": {
            "useExhaustiveDependencies": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/desktop/src/renderer/src/components/composer-workflow-auto.tsx",
        "apps/desktop/src/renderer/src/components/settings/workflow-step-card.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "useAriaPropsSupportedByRole": "off",
            "useSemanticElements": "off"
          }
        }
      }
    }
  ],
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
