# Copy to scripts/ollama-serve-safe.env (gitignored) and adjust.
# Used by scripts/ollama-serve-safe.sh and scripts/open-ollama-safe.sh
#
# Ollama server tuning (see `ollama serve --help`):
# https://github.com/ollama/ollama/blob/main/docs/faq.md

# Only one model resident at a time (unloads previous model before loading another).
OLLAMA_MAX_LOADED_MODELS=1

# One in-flight request per loaded model (reduces RAM multiplier).
OLLAMA_NUM_PARALLEL=1

# Unload idle models quickly so a huge pull does not stay resident.
OLLAMA_KEEP_ALIVE=30s

# Cap default context unless a Modelfile overrides it (lower = less KV RAM).
OLLAMA_CONTEXT_LENGTH=8192

# Let llama.cpp shrink layers to fit; keep a free-memory margin (MiB per device).
LLAMA_ARG_FIT=on
LLAMA_ARG_FIT_TARGET=6144

# Optional: hard virtual memory cap for the serve process (GiB). macOS ulimit -v only.
# Leave unset to rely on Ollama fit + concurrency limits above.
# PLANETZ_OLLAMA_ULIMIT_VIRT_GB=24

# Bind address (default loopback).
# OLLAMA_HOST=127.0.0.1:11434
