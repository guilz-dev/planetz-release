# Bundled orbit assets (generated by pnpm prepare:bundled-orbit)
resources/orbit/
apps/desktop/resources/orbit/
apps/desktop/resources/node/
apps/desktop/release/

# Legacy bundled takt paths (pre-orbit rename; safe to delete locally)
resources/takt/
apps/desktop/resources/takt/

# Per-workspace UI sidecar (local config/history; do not commit from opened workspaces)
**/.orbit/
**/.planets/
**/.planetz/
**/.takt-agent-ui/
!apps/desktop/fixtures/**/.orbit/
!apps/desktop/fixtures/**/.orbit/**
!apps/desktop/fixtures/**/.planets/
!apps/desktop/fixtures/**/.planets/**
!apps/desktop/fixtures/**/.planetz/
!apps/desktop/fixtures/**/.planetz/**
!apps/desktop/e2e/fixtures/**/.planetz/
!apps/desktop/e2e/fixtures/**/.planetz/**

apps/desktop/e2e/test-results/
apps/desktop/e2e/playwright-report/

artifacts/intro/

# Ephemeral agent / review output
.tmp/

# skills CLI may create agent-specific dirs; canonical skills live in .cursor/skills
.agents/
.claude/
.roo/
skills/
!packages/agent-belay/skills/
!packages/agent-belay/skills/**

# Cursor IDE — local workflow artifacts (see .cursor/commands/issue-workflow.md)
.cursor/issue-workflow/*
!.cursor/issue-workflow/.gitkeep

# Cursor IDE — machine/session state (worktree hint, local daemons)
.cursor/local-state/
